# Copy this file to keystore.properties (which is gitignored) and fill in real values to produce a
# signed release APK. Generate a keystore once with:
#
#   keytool -genkeypair -v -keystore mage-release.jks \
#       -keyalg RSA -keysize 4096 -validity 10000 -alias mage
#
# Then point the entries below at it. Without keystore.properties the release build still assembles,
# but the APK is unsigned and cannot be installed until you sign it.

storeFile=mage-release.jks
storePassword=CHANGEME
keyAlias=mage
keyPassword=CHANGEME
