<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera is used only to scan recipient public-key QR codes; declared optional so the app
         installs on camera-less devices. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- allowBackup=false already disables cloud backup, adb backup, and device-to-device
         transfer outright; dataExtractionRules only tunes what gets backed up when backup is
         on, so it's not needed here. -->
    <application
        android:name=".MageApp"
        android:allowBackup="false"
        android:largeHeap="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mage"
        tools:ignore="DataExtractionRules">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Long-press launcher shortcuts (Encrypt / Decrypt) -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Labeled share-sheet target: encrypt whatever was shared (any file type, or text). -->
        <activity-alias
            android:name=".ShareEncrypt"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="@string/share_target_encrypt">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
        </activity-alias>

        <!--
             Labeled share-sheet target: decrypt a shared .age file. age has no registered MIME
             type, so senders can't tag it precisely; unrecognized extensions almost universally
             resolve to "application/octet-stream" instead (unlike photos, video, audio, pdf, zip,
             apk, etc., which all have a specific registered type), so filtering on that keeps this
             target off the share sheet for ordinary files without requiring an exact match. It's a
             best-effort filter, not the enforcement boundary — SafIO.isAgeName does the real check
             once a file is actually picked.
        -->
        <activity-alias
            android:name=".ShareDecrypt"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="@string/share_target_decrypt">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
            <!-- Also offer to open .age files directly from a file manager. No host: per Android's
                 intent-filter matching, a scheme with no authority matches content:// URIs from
                 any provider, which is what we want (Downloads, Drive, other file managers, ...);
                 adding a host would wrongly restrict this to one specific provider. Lint's
                 AppLinkUrlError check is tuned for https:// web deep links and doesn't account for
                 that, hence the suppression. -->
            <intent-filter tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.age" />
            </intent-filter>
        </activity-alias>

        <!-- Quick Settings tile: tap to jump straight into Encrypt (phase 2). -->
        <service
            android:name=".tile.EncryptTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_lock"
            android:label="@string/tile_encrypt"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Shares produced outputs out to other apps via a content:// URI from the app's cache. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
